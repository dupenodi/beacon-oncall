# Postgres (Neon). Prefer sslmode=require; drop channel_binding=require if a client fails to connect.
DATABASE_URL=postgresql://user:pass@localhost:5432/beacon

# 32-byte AES key for encrypting org webhook secrets at rest (base64 or 64-char hex)
# Example: openssl rand -hex 32
APP_MASTER_KEY=

# API (Hono) — default local port
API_PORT=3001

# Web — used by the browser to call the API
NEXT_PUBLIC_API_URL=http://localhost:3001

# Session cookie (optional overrides)
# SESSION_COOKIE_NAME=beacon_session
# SESSION_TTL_SECONDS=1209600

# Demo users password when running `npm run db:seed` (argon2 hash stored in DB)
# DEMO_SEED_PASSWORD=demo

# CP06 — protect POST /internal/tick (min 32 chars; compare full string with timingSafeEqual)
# INTERNAL_TICK_SECRET=

# CP07 — email via Resend (optional; omit to use console notifier in dev)
# RESEND_API_KEY=
# EMAIL_FROM=Beacon <alerts@yourdomain.com>

# Deep links in notification emails
# PUBLIC_WEB_ORIGIN=http://localhost:3000

# Optional: log notifier subject/to when set to "1"
# DEBUG_NOTIFY=1

# CP09 — OpenAI for action agent (omit to use MockChatModel in dev/CI)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
