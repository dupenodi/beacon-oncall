# =============================================================================
# beacon-oncall — environment template
# Copy to `.env` and fill values: `cp .env.example .env`
# Never commit `.env`. Each section notes how to obtain the value.
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres (required for API + migrate/seed)
# -----------------------------------------------------------------------------
# Connection URL used by `apps/api`, `packages/db` migrate/seed, integration tests.
#
# How to get:
#   - Neon: https://neon.tech → project → Connection string (use "pooled" if offered).
#   - AWS RDS / GCP Cloud SQL / Supabase: use the provider's Postgres connection UI.
#   - Local: `postgresql://USER:PASS@localhost:5432/beacon`
#
# Tips: append `?sslmode=require` for cloud. If a client errors on channel_binding,
#       remove `channel_binding=require` from the URL if present.
DATABASE_URL=postgresql://user:pass@localhost:5432/beacon

# -----------------------------------------------------------------------------
# App crypto master key (required for API + seed)
# -----------------------------------------------------------------------------
# 32-byte key as 64-character hex OR base64. Encrypts org webhook secrets and
# GitHub PATs at rest. Changing it invalidates existing ciphertext — rotate secrets in-app.
#
# How to get:
#   openssl rand -hex 32
#   # or: openssl rand -base64 32   (then paste as one line, no spaces)
APP_MASTER_KEY=a368f775fde26d70ad16feeaa90cec7673771a36f03e55fd81c4edfbea3ac1ff

# -----------------------------------------------------------------------------
# Internal escalation tick (required in production if you call POST /internal/tick)
# -----------------------------------------------------------------------------
# Min 32 characters. Sent as header X-Internal-Auth on POST /internal/tick (timing-safe compare).
#
# How to get:
#   openssl rand -hex 32
#   # or any password manager random string ≥ 32 chars
INTERNAL_TICK_SECRET=db4179fffe9d0c857fc962aeb5ac0eb4a542da40c58e23c8993f05d6d8d952fa

# -----------------------------------------------------------------------------
# API server (apps/api)
# -----------------------------------------------------------------------------
# Listen port for local `node dist/index.js`. On Render/Railway/Fly, the platform sets **PORT**
# and the API uses that automatically (`PORT` overrides `API_PORT`).
# How: local → 3001 is fine. Hosted → leave unset and use the platform’s PORT.
API_PORT=3001

# production | development — platforms usually set NODE_ENV for you.
# NODE_ENV=production

# -----------------------------------------------------------------------------
# Web app (apps/web) — exposed to the browser
# -----------------------------------------------------------------------------
# Public origin of the API as seen from the user's browser (scheme + host, no trailing slash).
# Local dev: same as API. Production: your deployed API URL.
#
# How to get: the URL you open for /health, e.g. https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Session cookie (optional overrides)
# -----------------------------------------------------------------------------
# SESSION_COOKIE_NAME=beacon_session
# SESSION_TTL_SECONDS=1209600

# -----------------------------------------------------------------------------
# Seed script only (packages/db seed) — optional
# -----------------------------------------------------------------------------
# Argon2 password for demo users (owner@demo.invalid, oncall@demo.invalid).
# How: choose a strong password for non-prod environments; default in code is "demo" if unset.
# DEMO_SEED_PASSWORD=demo

# -----------------------------------------------------------------------------
# Email notifications (optional — omit = console notifier, no email)
# -----------------------------------------------------------------------------
# Resend API key from https://resend.com → API Keys. Needs verified domain for "from".
# RESEND_API_KEY=re_xxxxxxxx
#
# "From" must use a domain you've verified in Resend (Domains).
# EMAIL_FROM=Beacon <alerts@yourdomain.com>

# -----------------------------------------------------------------------------
# Links inside notification emails (optional)
# -----------------------------------------------------------------------------
# Base URL of the web app for incident links in email text.
# How: your deployed Next app origin, e.g. https://app.yourdomain.com
# PUBLIC_WEB_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Debugging (optional)
# -----------------------------------------------------------------------------
# DEBUG_NOTIFY=1

# -----------------------------------------------------------------------------
# Action agent / OpenAI (optional — omit = MockChatModel)
# -----------------------------------------------------------------------------
# How: https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
#
# Runs use OpenAI only in the **API** process. On Render, set this on the API service (not the
# web app) and redeploy. GET https://<api-host>/health includes openAiConfigured (no secret).
#
# GitHub issue for agent comments: the model may guess a wrong issue → 404. Set a real issue id:
# BEACON_GITHUB_ISSUE_NUMBER=1
#
# Without OPENAI_API_KEY the mock agent defaults to issue **1** in the org default repo.
# Legacy override (still honored; use BEACON_GITHUB_ISSUE_NUMBER if both are set):
# BEACON_MOCK_GITHUB_ISSUE_NUMBER=42

# -----------------------------------------------------------------------------
# Optional: “live” traffic (local CLI + same names as GitHub Actions secrets)
# -----------------------------------------------------------------------------
# After `npm run db:seed`, copy serviceId from the log. Use the same values in
# GitHub → Settings → Secrets → Actions for simulate.yml / tick.yml.
#
#   SIM_BASE_URL=https://your-api.example.com    # no trailing slash; or http://127.0.0.1:3001 locally
#   SIM_ORG_SLUG=demo
#   SIM_SERVICE_ID=<uuid from seed log>
#   SIM_WEBHOOK_SECRET=whsec_dev_demo_change_me  # unless you rotated the org webhook secret
#
# Then from repo root (API must be running and reachable at SIM_BASE_URL):
#   npm run live:webhook
#   npm run live:tick
#
# =============================================================================
# GitHub Actions (not in .env — repo Settings → Secrets and variables → Actions)
# =============================================================================
#
# tick.yml — POST /internal/tick (use same values as SIM_BASE_URL + INTERNAL_TICK_SECRET here):
#   API_BASE_URL          same as SIM_BASE_URL (public API origin, no trailing slash)
#   INTERNAL_TICK_SECRET  must match the API server env of the same name
#
# simulate.yml — synthetic webhooks (same four names as the optional block above):
#   SIM_BASE_URL
#   SIM_ORG_SLUG
#   SIM_SERVICE_ID
#   SIM_WEBHOOK_SECRET
#
# If secrets are missing, those workflows exit 0 and print a skip line (safe defaults).
