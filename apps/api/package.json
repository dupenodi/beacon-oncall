    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.6",
    "resend": "^6.12.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.28.0",
    "@types/node": "^22.14.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.3"
  }
