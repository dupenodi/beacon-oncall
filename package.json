{
  "name": "beacon-oncall",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm run dev -w @beacon/api\" \"npm run dev -w @beacon/web\"",
    "build": "npm run build -w @beacon/web && npm run build -w @beacon/api",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run generate -w @beacon/db",
    "db:migrate": "npm run migrate -w @beacon/db",
    "db:seed": "npm run seed -w @beacon/db"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
